// Location: server/ephemerisService.ts
//
// Install: npm install swisseph
//
// Replaces the approximate fallback calculators in astrologyService.ts with
// professional-grade ephemeris calculations. Used as primary source when
// Prokerala API endpoints return 403 (plan restriction).
// ─────────────────────────────────────────────────────────────────────────────

let swisseph: any = null;

// Lazy load — if swisseph is not installed, all functions gracefully return null
async function getSwe(): Promise<any> {
  if (swisseph) return swisseph;
  try {
    swisseph = await import('swisseph');
    // Use built-in ephemeris data (no external files needed)
    swisseph.swe_set_ephe_path('');
    console.log('[Ephemeris] Swiss Ephemeris loaded ✅');
    return swisseph;
  } catch (err) {
    console.warn('[Ephemeris] swisseph not available, fallback will be used:', (err as Error).message);
    return null;
  }
}

// ── Types ─────────────────────────────────────────────────────────────────────

export interface EphemerisPlanetPosition {
  planet: string;
  longitude: number;       // 0–360 degrees (sidereal / Lahiri ayanamsa)
  sign: string;            // Aries … Pisces
  degree: number;          // 0–30 degrees within sign
  minutes: number;         // 0–60 arc minutes
  retrograde: boolean;
  nakshatra: string;       // which nakshatra the planet is in
  nakshatraPada: number;   // 1–4
}

export interface EphemerisPanchang {
  tithi: string;
  tithiNumber: number;     // 1–30
  tithiPercent: number;    // % of tithi elapsed
  nakshatra: string;
  nakshatraNumber: number; // 1–27
  nakshatraPercent: number;
  yoga: string;
  yogaNumber: number;      // 1–27
  karana: string;
  karanaNumber: number;    // 1–11
  lunarPhase: string;
  lunarIllumination: number; // 0–100%
  sunriseIST: string;      // "HH:MM"
  sunsetIST:  string;      // "HH:MM"
}

export interface EphemerisKalam {
  rahuKalamStart:      string;
  rahuKalamEnd:        string;
  gulikaKalamStart:    string;
  gulikaKalamEnd:      string;
  yamghantaKalamStart: string;
  yamghantaKalamEnd:   string;
}

export interface EphemerisData {
  planetaryPositions: EphemerisPlanetPosition[];
  panchang:           EphemerisPanchang;
  kalam:              EphemerisKalam;
  hora:               string;   // current hora ruler
  ayanamsa:           number;   // Lahiri ayanamsa in degrees
  source:             'swisseph';
}

